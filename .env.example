DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
LLM_PROVIDER=crs
WIRE_API=responses
LLM_TIMEOUT_SECONDS=60
CRS_API_KEY=
CRS_BASE_URL=https://crs.acerobotics.com/openai
CRS=gpt-5.5

EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BACKEND=bge
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=8
EMBEDDING_USE_FP16=false

OCR_ENABLED=false
OCR_LANG=ch
OCR_MIN_TEXT_CHARS=80
OCR_MAX_PAGES_PER_FILE=20
OCR_RENDER_SCALE=1.5

# PDF large-file handling:
# Number of PDF pages parsed per batch before writing a SQLite checkpoint.
# Lower values reduce peak memory for very large PDFs. Set to 0 to disable batching.
PDF_PAGE_BATCH_SIZE=50
# Fall back to pymupdf (fitz) when pdfplumber cannot open a PDF (corrupt / unusual structure).
PDF_PYMUPDF_FALLBACK=true

CHROMA_PATH=data/chroma
CHROMA_COLLECTION=sensor_documents
SQLITE_PATH=data/sensor_rag.db
LOG_FILE=logs/sensor_rag.log

CHUNK_SIZE=512
CHUNK_OVERLAP=128
SEARCH_TOP_K=8
SEMANTIC_WEIGHT=0.65
BM25_WEIGHT=0.35
NATIVE_THREAD_LIMIT=4
